% --- Lingkungan Baru untuk Otomatisasi Daftar Rumus ---
% Lingkungan ini akan membungkus 'equation' dan 'align' serta secara otomatis
% menambahkan entri ke Daftar Rumus.
% Anda perlu mengganti \begin{equation} dengan \begin{myequation}{deskripsi}
% dan \begin{align} dengan \begin{myalign}{deskripsi}

\makeatletter % Memungkinkan penggunaan karakter '@' dalam nama perintah
% Define a temporary storage for the equation number and description
\newcommand{\@tempeqnum}{}
\newcommand{\@tempdescription}{} % New: to store the description

\newenvironment{myequation}[1]{%
  \gdef\@tempdescription{#1}% Store the description here
  \begin{equation}%
  \gdef\@tempeqnum{(\theequation)}% Store the current equation number (e.g., (1.1))
}{%
  \addcontentsline{loe}{equs}{\protect\numberline{\@tempeqnum} \@tempdescription}% Use the stored description
  \end{equation}%
}

