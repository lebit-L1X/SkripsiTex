% link page numbers in TOC 
\makeatletter
\def\contentsline#1#2#3#4{%
  \ifx\\#4\\%
    \csname l@#1\endcsname{#2}{#3}%
  \else
    \csname l@#1\endcsname{%
      \hyper@linkstart{link}{#4}{#2}\hyper@linkend
    }{%
      % same link destination for the page:
      \hyper@linkstart{link}{#4}{#3}\hyper@linkend
      % link destination is the page itself:
      % \hyperpage{#3}%
    }%
  \fi
}
% MODIFIKASI: Mengubah \renewcommand\section, \subsection, \subsubsection untuk ukuran font 12pt
% Ini adalah definisi \section yang ada di preamble Anda.
\renewcommand\section{\@startsection {section}{1}{\z@}%
                      {-3.5ex \@plus -1ex \@minus -.2ex}%
                      {2.3ex \@plus.2ex}%
                      {\normalsize\bfseries}} % Mengubah \large menjadi \normalsize (12pt)

% Menambahkan definisi \subsection dan \subsubsection untuk ukuran font 12pt
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
                       {-3.25ex\@plus -1ex \@minus -.2ex}%
                       {1.5ex \@plus .2ex}%
                       {\normalsize\bfseries}} % Mengatur ke \normalsize (12pt)

\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
                       {-3.25ex\@plus -1ex \@minus -.2ex}%
                       {1.5ex \@plus .2ex}%
                       {\normalsize\bfseries}} % Mengatur ke \normalsize (12pt)
\makeatother

