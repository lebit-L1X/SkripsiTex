\usepackage[font=small,format=plain,labelfont=bf,up,textfont=up,labelsep=period]{caption}

% Untuk TABEL (caption di atas)
% 'above' mengatur jarak antara teks di atasnya dengan caption.
% 'below' mengatur jarak antara caption dengan tabelnya.
\captionsetup[table]{
    font=footnotesize,
    skip=15pt, % Jarak antara caption dan tabel (Anda ingin ini rapat)
    position=top, % Pastikan caption selalu di atas,
    justification=centering
}

% Untuk GAMBAR (caption di bawah)
% 'above' mengatur jarak antara gambar dengan caption di bawahnya.
% 'below' mengatur jarak antara caption dengan teks di bawahnya.
\captionsetup[figure]{
    font=footnotesize,
    skip=15pt, % Jarak antara gambar dan caption (Anda ingin ini rapat)
    position=bottom, % Pastikan caption selalu di bawah
    justification=centering
}

\makeatletter
\newcommand{\printfontsize}{\f@size pt}
\makeatother

% Pengaturan untuk Kode (mengikuti format Tabel)
\captionsetup[listing]{
    font=footnotesize,
    skip=15pt,  % Jarak 1.5 spasi antara caption dan bingkai kode
    position=top,          % Posisi caption DI ATAS
    justification=centering
}

